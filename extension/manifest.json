{
  "manifest_version": 3,
  "name": "JobTrail",
  "version": "1.0.0",
  "description": "One-click job application tracker. Auto-fills from any job board.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobTrail",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://boards.eu.greenhouse.io/*",
        "https://ashbyhq.com/*",
        "https://jobs.ashbyhq.com/*",
        "https://app.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://www.indeed.com/viewjob*",
        "https://www.indeed.com/jobs*",
        "https://app.joinhandshake.com/*",
        "https://joinhandshake.com/*",
        "https://*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
